{
  "name": "landinuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/sync-element-assets.mjs && nuxt build",
    "dev": "node scripts/sync-element-assets.mjs && nuxt dev",
    "dev:clean": "rm -rf .nuxt && nuxt dev",
    "dev:reset": "lsof -ti :3000 | xargs kill -9 2>/dev/null; rm -rf .nuxt node_modules/.cache && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "verify:elements": "node scripts/verify-element-counts.mjs",
    "typecheck": "nuxi typecheck",
    "check": "bun run verify:elements && bun run typecheck && bun run build"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.115",
    "@iconify-json/simple-icons": "1.2.88",
    "@nuxt/content": "3.14.0",
    "@nuxt/devtools": "latest",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "4.9.0",
    "@tailwindcss/typography": "0.5.15",
    "nuxt": "4.4.8",
    "prettier": "3.9.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss-animate": "1.0.7",
    "typescript": "6.0.3",
    "vue-tsc": "3.3.6"
  },
  "packageManager": "bun@latest",
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "vue": "latest"
  },
  "dependencies": {
    "@nuxtjs/seo": "5.3.1",
    "@vueuse/core": "14.3.0",
    "@vueuse/motion": "3.0.3",
    "better-sqlite3": "^12.11.1",
    "node-html-parser": "8.0.4",
    "shiki": "4.3.0"
  }
}
